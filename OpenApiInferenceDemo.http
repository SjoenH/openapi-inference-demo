@OpenApiInferenceDemo_HostAddress = http://localhost:5076

# =============================================================================
# Basic CRUD Operations
# =============================================================================

# Get demo item (returns 200 with DemoDto)
GET {{OpenApiInferenceDemo_HostAddress}}/demo/5
Accept: application/json

###

# Get demo item with invalid ID (returns 404)
GET {{OpenApiInferenceDemo_HostAddress}}/demo/0
Accept: application/json

###

# Create new demo item (returns 201 Created)
POST {{OpenApiInferenceDemo_HostAddress}}/demo
Content-Type: application/json

{
  "name": "New Demo Item",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Create demo item with missing name (returns 400 Bad Request)
POST {{OpenApiInferenceDemo_HostAddress}}/demo
Content-Type: application/json

{
  "name": "",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Update demo item (returns 200 OK)
PUT {{OpenApiInferenceDemo_HostAddress}}/demo/5
Content-Type: application/json

{
  "name": "Updated Demo Item",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Update demo item with invalid ID (returns 404)
PUT {{OpenApiInferenceDemo_HostAddress}}/demo/0
Content-Type: application/json

{
  "name": "Updated Demo Item",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Update system item (returns 403 Forbidden)
PUT {{OpenApiInferenceDemo_HostAddress}}/demo/999
Content-Type: application/json

{
  "name": "Updated System Item",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Delete demo item (returns 204 No Content)
DELETE {{OpenApiInferenceDemo_HostAddress}}/demo/5

###

# Delete demo item with invalid ID (returns 404)
DELETE {{OpenApiInferenceDemo_HostAddress}}/demo/0

###

