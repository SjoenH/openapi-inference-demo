# Status Code Testing Endpoints
# =============================================================================

# Test 200 OK
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/200

###

# Test 201 Created
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/201

###

# Test 202 Accepted
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/202

###

# Test 204 No Content
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/204

###

# Test 400 Bad Request
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/400

###

# Test 401 Unauthorized
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/401

###

# Test 403 Forbidden
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/403

###

# Test 404 Not Found
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/404

###

# Test 409 Conflict
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/409

###

# Test 422 Unprocessable Entity
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/422

###

# Test 500 Internal Server Error
GET {{OpenApiInferenceDemo_HostAddress}}/demo/status/500

###

# =============================================================================
# Validation Testing Endpoints
# =============================================================================

# Valid validation request
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "Valid Item",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Empty name (returns 422)
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Whitespace name (returns 422)
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "   ",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Name too long (returns 422)
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "This is a very long name that exceeds the fifty character limit",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Reserved name (returns 403)
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "admin",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# Conflicting name (returns 409)
POST {{OpenApiInferenceDemo_HostAddress}}/demo/validation
Content-Type: application/json

{
  "name": "conflict",
  "createdAt": "2023-01-01T00:00:00Z"
}

###

# =============================================================================
# Additional Status Code Examples
# =============================================================================

# Server error endpoint
GET {{OpenApiInferenceDemo_HostAddress}}/demo/server-error

###

# Accepted endpoint
GET {{OpenApiInferenceDemo_HostAddress}}/demo/accepted

###
